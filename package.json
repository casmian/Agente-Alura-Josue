{
  "name": "agente-alura-josue",
  "version": "1.0.0",
  "description": "Agente cognitivo corporativo para la plataforma educativa Alura desplegable en OCI",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "dev": "ts-node-dev --respawn --transpile-only server/index.ts",
    "db:migrate": "ts-node server/db/migrate.ts",
    "db:seed": "ts-node server/agent/ingestionService.ts",
    "client:install": "cd client && npm install",
    "client:dev": "cd client && npm run dev"
  },
  "dependencies": {
    "@google/genai": "^0.1.1",
    "cheerio": "^1.0.0-rc.12",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mammoth": "^1.7.2",
    "officeparser": "^4.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "cors": "^2.8.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
